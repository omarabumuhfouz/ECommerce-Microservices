            // Quick filter functionality
            $('.filter-badge').click(function() {
                // Remove active class from all badges
                $('.filter-badge').removeClass('bg-dark').addClass('bg-light text-dark');
                // Add active class to clicked badge
                $(this).removeClass('bg-light text-dark').addClass('bg-dark text-white');
                
                // In a real application, this would filter the table
                // For this demo, we'll just show a message
                const filterText = $(this).text();
                alert(`Filtering by: ${filterText}`);
            });
        });
