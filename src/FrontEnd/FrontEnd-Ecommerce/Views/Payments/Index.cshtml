                                </tbody>
                            </table>
                        </div>

                        <!-- Details Sections -->
                        <div id="details-7852" class="payment-details">
                            <h6>Payment Details: #PAY-7852</h6>
                            <div class="row">
                                <div class="col-md-6">
                                    <p><strong>Customer:</strong> John Smith (john.s@example.com)</p>
                                    <p><strong>Order Date:</strong> 2023-10-14</p>
                                    <p><strong>Payment Date:</strong> 2023-10-14 14:32</p>
                                </div>
                                <div class="col-md-6">
                                    <p><strong>Order Total:</strong> $245.99</p>
                                    <p><strong>Payment Method:</strong> Credit Card (**** **** **** 1234)</p>
                                    <p><strong>Status:</strong> <span class="badge bg-success status-badge">Completed</span></p>
                                </div>
                            </div>
                            <div class="row mt-2">
                                <div class="col-12">
                                    <h6>Transaction Details:</h6>
                                    <div class="product-item">
                                        <div>Transaction ID</div>
                                        <div>TXN-789456123</div>
                                    </div>
                                    <div class="product-item">
                                        <div>Authorization Code</div>
                                        <div>AUTH-789456</div>
                                    </div>
                                    <div class="product-item">
                                        <div>Payment Gateway</div>
                                        <div>Stripe</div>
                                    </div>
                                </div>
                            </div>
                            
                            <h6 class="mt-4">Payment Timeline</h6>
                            <div class="timeline">
                                <div class="timeline-item">
                                    <div class="timeline-date">2023-10-14 14:30</div>
                                    <div class="timeline-content">Payment initiated by customer</div>
                                </div>
                                <div class="timeline-item success">
                                    <div class="timeline-date">2023-10-14 14:32</div>
                                    <div class="timeline-content">Payment successfully processed</div>
                                </div>
                                <div class="timeline-item success">
                                    <div class="timeline-date">2023-10-14 14:35</div>
                                    <div class="timeline-content">Order confirmed</div>
                                </div>
                            </div>
                            
