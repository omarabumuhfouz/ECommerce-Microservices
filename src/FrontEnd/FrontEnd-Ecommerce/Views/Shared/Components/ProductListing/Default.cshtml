@model List<Product>

<div class="col-lg-9">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3>Featured Products</h3>
        <div class="d-flex">
            <div class="btn-group me-2">
                <button class="btn btn-outline-primary active"><i class="fas fa-th"></i></button>
                <button class="btn btn-outline-primary"><i class="fas fa-list"></i></button>
            </div>
            <span class="text-muted">Showing 1-@Model.Count of @Model.Count products</span>
        </div>
    </div>

    <div class="row">
        @foreach (var product in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card product-card">
                    @if (!string.IsNullOrEmpty(product.Badge))
                    {
                        <span class="badge bg-danger discount-badge">@product.Badge</span>
                    }
                    <img src="@product.ImageUrl" class="card-img-top product-image" alt="@product.Name" />
                    <div class="card-body">
                        <h5 class="card-title">@product.Name</h5>
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <span class="price">$@product.Price</span>
                                @if (product.OldPrice.HasValue)
                                {
                                    <span class="text-muted text-decoration-line-through ms-2">$@product.OldPrice</span>
                                }
                            </div>
                            <div>
                                <small class="text-warning">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        if (product.Rating >= i) { <i class="fas fa-star"></i> }
                                        else if (product.Rating > i - 1) { <i class="fas fa-star-half-alt"></i> }
                                        else { <i class="far fa-star"></i> }
                                    }
                                </small>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer bg-white d-flex justify-content-between">


                       @*Favirate Product Do it in Feutrue*@
                        <button class="btn btn-sm btn-outline-primary"><i class="fas fa-heart"></i></button> 

                        @*Add to Cart*@
                        <a asp-controller="Carts"
                            asp-action="Add"
                            asp-route-id="@product.Id"
                            class="btn btn-sm btn-primary">
                         Add to Cart
                        </a>


                            @* View Product Detials *@
                           <a asp-controller="Products" 
                             asp-action="Details" 
                             asp-route-id="@product.Id" 
                             class="btn btn-sm btn-outline-secondary">
                                <i class="fas fa-eye"></i>  @* icon *@
                           </a>


                      



                    </div>
                </div>
            </div>
        }
    </div>

    @await Component.InvokeAsync("Pagination", new { currentPage = 1, totalPages = 5 })
</div>
