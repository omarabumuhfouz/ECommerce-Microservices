@model List<FrontEnd_Ecommerce.Models.FeedbackViewModel>

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
                <h6 class="m-0 font-weight-bold text-primary">Recent Customer Feedback</h6>
                <a href="#" class="btn btn-sm btn-primary">View All</a>
            </div>
            <div class="card-body">
                <div class="row">
                    @foreach(var fb in Model)
                    {
                        <div class="col-lg-6 mb-4">
                            <div class="card bg-light">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between">
                                        <h6 class="card-title">@fb.Customer</h6>
                                        <div class="text-warning">
                                            @for(int i=0; i<fb.Stars; i++)
                                            {
                                                <i class="fas fa-star"></i>
                                            }
                                            @for(int i=fb.Stars; i<5; i++)
                                            {
                                                <i class="far fa-star"></i>
                                            }
                                        </div>
                                    </div>
                                    <p class="card-text">"@fb.Comment"</p>
                                    <div class="d-flex justify-content-between">
                                        <small class="text-muted">Order @fb.OrderId</small>
                                        <small class="text-muted">@fb.Date</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
