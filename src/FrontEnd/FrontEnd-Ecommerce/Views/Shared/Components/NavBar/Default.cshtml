@model NavBarViewModel


<nav class="navbar navbar-expand-lg navbar-dark sticky-top">
    <div class="container">
        <a class="navbar-brand" asp-controller="Home" asp-action="Index">
            <i class="fas fa-shopping-bag me-2"></i>ShopNow
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav me-auto">
                <li class="nav-item"><a class="nav-link active" asp-controller="Home" asp-action="Index">Home</a></li>
                <li class="nav-item"><a class="nav-link" asp-controller="Categories" asp-action="Index">Categories</a></li>
                <li class="nav-item"><a class="nav-link" asp-controller="Deals" asp-action="Index">Deals</a></li>
                <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="About">About</a></li>
                <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Contact">Contact</a></li>
            </ul>

            <div class="d-flex align-items-center">
                <div class="input-group me-2">
                    <input type="text" class="form-control" placeholder="Search products...">
                    <button class="btn btn-primary" type="button">
                        <i class="fas fa-search"></i>
                    </button>
                </div>

                <a asp-controller="Carts" asp-action="Index" class="btn btn-outline-light position-relative me-2">
                    <i class="fas fa-shopping-cart"></i>
                    <span class="cart-count">@Model.CartCount</span>
                </a>

                @if (@Model.IsAuthenticated)
                {
                          <!-- Authenticated User - Logout Icon -->
                    <div class="d-flex align-items-center">
                        <!-- User Profile Icon -->
                        <a asp-controller="Account" asp-action="Profile" class="btn btn-outline-light me-2" 
                           title="My Profile">
                            <i class="bi bi-person-circle"></i>
                        </a>
                        
                        <!-- Logout Icon -->
                        <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-danger" 
                           title="Logout">
                            <i class="bi bi-box-arrow-right"></i>
                        </a>
                    </div>
                }
                else
                {
                    <a class="btn btn-outline-light me-2" asp-controller="Testing" asp-action="AdmainTest">Admain</a>
                    <a class="btn btn-outline-light me-2" asp-controller="Account" asp-action="Login">Login</a>
                    <a class="btn btn-primary" asp-controller="Account" asp-action="Register">Register</a>
                }
            </div>
        </div>
    </div>
</nav>

<script>
function toggleDropdown() {
    var menu = document.getElementById('dropdownMenu');
    menu.classList.toggle('show');
}
</script>