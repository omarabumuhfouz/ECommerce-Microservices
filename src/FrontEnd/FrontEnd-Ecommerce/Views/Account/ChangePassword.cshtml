@model FrontEnd_Ecommerce.DTOs.Auth.Requests.ChangePasswordRequestDto

@{
    ViewData["Title"] = "Change Password";
}

<link rel="stylesheet" href="~/css/ChangePassword.css" asp-append-version="true" />

<div class="container mt-4">
    <div class="password-container">
        <div class="card password-card">
            <div class="password-header text-center">
                <h3 class="mb-1">
                    <i class="fas fa-key me-2"></i>Change Password
                </h3>
                <p class="mb-0 opacity-75">Update your account password</p>
            </div>
            
            <div class="card-body p-4">
                <!-- Use asp-action and asp-controller to point to the correct handler -->
                <form asp-action="ChangePassword" asp-controller="Account" method="post">
                    @Html.AntiForgeryToken() <!-- ✅ Important for security -->

                    <div class="form-group mb-3">
                        <label asp-for="CurrentPassword" class="form-label"></label>
                        <input asp-for="CurrentPassword" class="form-control" type="password" 
                               placeholder="Enter your current password" required />
                        <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="NewPassword" class="form-label"></label>
                        <input asp-for="NewPassword" class="form-control" type="password" 
                               placeholder="Enter new password" required />
                        <div class="password-strength" id="passwordStrength"></div>
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="ConfirmNewPassword" class="form-label"></label>
                        <input asp-for="ConfirmNewPassword" class="form-control" type="password"
                               placeholder="Confirm your new password" required />
                        <span asp-validation-for="ConfirmNewPassword" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2 flex-wrap">
                        <button type="submit" class="btn btn-danger btn-password">
                            <i class="fas fa-save me-2"></i>Update Password
                        </button>
                        <a asp-controller="Account" asp-action="Profile" class="btn btn-outline-secondary btn-password">
                            <i class="fas fa-arrow-left me-2"></i>Back to Profile
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- For client-side validation -->
    <partial name="_ValidationScriptsPartial" />
}
