@model FrontEnd_Ecommerce.DTOs.Auth.Requests.EditProfileRequestDto;

@{
    ViewData["Title"] = "Edit Profile";
}

<link rel="stylesheet" href="~/css/EditProfile.css" asp-append-version="true" />


<div class="container mt-4">
    <div class="profile-edit-container">
        <div class="card profile-edit-card">
            <div class="profile-edit-header text-center">
                <h3 class="mb-1">
                    <i class="fas fa-user-edit me-2"></i>Edit Profile
                </h3>
                <p class="mb-0 opacity-75">Update your personal information</p>
            </div>
            
            <div class="card-body p-4">
                <form method="post" asp-action="EditProfile">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="form-label" asp-for="FirstName">First Name</label>
                                <input type="text" class="form-control" asp-for="FirstName" 
                                       placeholder="Enter your first name" required>
                                <span asp-validation-for="FirstName" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="form-label" asp-for="LastName">Last Name</label>
                                <input type="text" class="form-control" asp-for="LastName" 
                                       placeholder="Enter your last name" required>
                                <span asp-validation-for="LastName" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>
                    
                    <div class="form-group">
                        <label class="form-label" asp-for="Email">Email Address</label>
                        <input type="email" class="form-control" asp-for="Email" 
                               placeholder="Enter your email address" required>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    
                    <div class="d-flex gap-2 flex-wrap mt-4">
                        <button type="submit" class="btn btn-primary btn-profile-edit">
                            <i class="fas fa-save me-2"></i>Save Changes
                        </button>
                        <a asp-action="Profile" asp-controller="Account" class="btn btn-outline-secondary btn-profile-edit">
                            <i class="fas fa-times me-2"></i>Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>