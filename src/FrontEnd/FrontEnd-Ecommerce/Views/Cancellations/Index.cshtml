    <script>
        $(document).ready(function() {
            // Cancellation Reason Chart
            var ctx = document.getElementById("cancellationReasonChart").getContext('2d');
            var cancellationReasonChart = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: ["Changed Mind", "Found Cheaper", "Delivery Delay", "Wrong Item", "Product Issue", "Other"],
                    datasets: [{
                        label: 'Number of Cancellations',
                        data: [42, 35, 28, 12, 8, 2],
                        backgroundColor: [
                            'rgba(78, 115, 223, 0.7)',
                            'rgba(54, 185, 204, 0.7)',
                            'rgba(246, 194, 62, 0.7)',
                            'rgba(231, 74, 59, 0.7)',
                            'rgba(28, 200, 138, 0.7)',
                            'rgba(133, 135, 150, 0.7)'
                        ],
                        borderColor: [
                            'rgba(78, 115, 223, 1)',
                            'rgba(54, 185, 204, 1)',
                            'rgba(246, 194, 62, 1)',
                            'rgba(231, 74, 59, 1)',
                            'rgba(28, 200, 138, 1)',
                            'rgba(133, 135, 150, 1)'
                        ],
                        borderWidth: 1
                    }]
                },
                options: {
                    maintainAspectRatio: false,
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                stepSize: 10
                            }
                        }
                    },
                    plugins: {
                        legend: {
                            display: false
                        }
                    }
                }
            });
            
            // Status Chart
            var ctx2 = document.getElementById("statusChart").getContext('2d');
            var statusChart = new Chart(ctx2, {
                type: 'doughnut',
                data: {
                    labels: ["Pending Review", "Approved", "Rejected", "Refund Processed", "Cancelled"],
                    datasets: [{
                        data: [24, 65, 18, 15, 5],
                        backgroundColor: ['#4e73df', '#1cc88a', '#e74a3b', '#36b9cc', '#858796'],
                        hoverBackgroundColor: ['#2e59d9', '#17a673', '#be2617', '#2c9faf', '#60616f'],
                        hoverBorderColor: "rgba(234, 236, 244, 1)",
                    }],
                },
                options: {
                    maintainAspectRatio: false,
                    cutout: '70%',
                    plugins: {
                        legend: {
                            display: false
                        }
                    }
                }
            });
            
            // View details functionality
            $('.view-details').click(function() {
                var id = $(this).data('id');
                $('.cancellation-details').removeClass('details-show');
                $('#details-' + id).addClass('details-show');
            });
            
            // Close details functionality
            $('.close-details').click(function() {
                var id = $(this).data('id');
                $('#details-' + id).removeClass('details-show');
            });
        });
    </script>
</body>
</html>